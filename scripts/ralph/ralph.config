# Ralph Framework Configuration
# Source this file to override defaults in ralph.sh

# Where prd.json lives. Default: scripts/ralph/ directory (SCRIPT_DIR)
# Set to "$REPO_ROOT" to place prd.json in the repository root instead.
# PRD_DIR="$SCRIPT_DIR"

# JSON field name for the stories array in prd.json.
# Auto-detected if empty: checks for "stories" first, then "userStories".
# STORIES_FIELD="stories"

# Command to install dependencies in worktrees (ralph.sh only).
# INSTALL_CMD="npm install --ignore-scripts --no-audit --no-fund"
